      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{5B0FA405-8895-420B-BF33-C987C49168BF}"
          SQLTask:SqlStatementSource="INSERT INTO dim_mo (mo_code, mo_name)&#xA;SELECT DISTINCT &#xA;    CAST(value AS INT),&#xA;    NULL&#xA;FROM stg_mo_raw&#xA;CROSS APPLY STRING_SPLIT(mo_codes_raw, ' ')&#xA;WHERE TRY_CAST(value AS INT) IS NOT NULL&#xA;AND CAST(value AS INT) NOT IN (SELECT mo_code FROM dim_mo);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
